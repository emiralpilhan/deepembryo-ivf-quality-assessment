.ruff_cache/

# Virtual environments and local environment files
.venv/
venv/
env/
ENV/
.env
.env.*

# Editor / OS files
.vscode/
.idea/
.DS_Store
Thumbs.db
desktop.ini

# Logs and temporary runtime files
*.log
outputs/training.log

# Large trained model/checkpoint files
