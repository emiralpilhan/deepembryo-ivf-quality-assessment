*.h5
*.hdf5
*.keras
*.ckpt
*.pkl
*.joblib
outputs/models/

# Non-final experiment outputs
outputs/experiments/

# Heavy generated Grad-CAM image outputs
outputs/gradcam/

# Web runtime artifacts
webapp/deepembryo.db
webapp/uploads/
*.db
*.sqlite
*.sqlite3

# Generated PDF extraction helper files
outputs/reports/pdf_requirements_extracted*.txt

# Raw datasets and local course archives should not be committed
EMBRIO GRADE DATASET/
datasets/
data/raw/
*.bmp
*.zip
*.rar
*.7z

